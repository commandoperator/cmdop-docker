# One Cmdop platform key is used for inference and, in public relay mode,
# registration with the Cmdop edge.
CMDOP_API_KEY=

# "auto" selects public when CMDOP_PUBLIC_SUBDOMAIN is set, otherwise LAN.
# Set "public" with an empty subdomain to reuse the address already provisioned
# for this key's organization.
CMDOP_RELAY_MODE=auto
CMDOP_PUBLIC_SUBDOMAIN=

# ── Agent mode ───────────────────────────────────────────────────────────────
# Join an EXISTING Cmdop server as one more machine instead of running the
# full workspace:  docker compose --profile agent up --build agent
# Server address, e.g. https://my-team.cmdop.dev or http://192.168.1.10:63141
CMDOP_SERVER_URL=
# Fleet enrollment password from that server (/admin/enrollment page, or the
# password the server prints on startup).
CMDOP_ENROLL_PASSWORD=
# Set 1 only for a self-hosted server with a self-signed certificate.
CMDOP_SERVER_INSECURE=0

# Initial browser-console password. Compose mounts this as a secret file; Cmdop
# reads it only when its durable database has no admin credential.
CMDOP_ADMIN_PASSWORD=change-this-local-password

# Keep "default" for normal approval prompts. Use "bypass" only in a
# disposable, isolated recording environment.
CMDOP_PERMISSIONS_MODE=default

# Workspace exposed to inbound chats with this Docker machine.
CMDOP_AGENT_CWD=/workspace/demo

# Identity used for local commits made in the isolated demo repository.
CMDOP_GIT_AUTHOR_NAME=Cmdop Agent
CMDOP_GIT_AUTHOR_EMAIL=agent@cmdop.local

# Bind to loopback by default so the development UI and admin console are not
# exposed to the LAN. Set 0.0.0.0 deliberately when remote LAN access is needed.
HOST_BIND_ADDRESS=127.0.0.1

# Host ports. Container ports are stable runtime contracts.
DEMO_HOST_PORT=8080
CMDOP_HOST_PORT=63141

# Helps bind-mounted files stay writable on Linux. Run `id -u` and `id -g`.
HOST_UID=1000
HOST_GID=1000

# Build-time: headless Chromium for the agent's browser tools. Set 0 for a
# slimmer image; the agent then simply runs without browser tools.
CMDOP_BROWSER=1

# Polling is the most reliable watcher mode across Docker Desktop mounts.
VITE_USE_POLLING=true
VITE_POLL_INTERVAL_MS=300

# Optional public HMR port when a reverse proxy maps WebSockets separately.
VITE_HMR_CLIENT_PORT=
